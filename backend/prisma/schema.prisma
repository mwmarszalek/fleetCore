generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CENTRAL_DISPATCHER
  DEPOT_DISPATCHER
  DRIVER
}

model User {
  id           String   @id @default(uuid())
  email        String
  passwordHash String
  role         UserRole
  cityId       String
  depotId      String?  // DEPOT_DISPATCHER + DRIVER
  vehicleId    String?  // DRIVER only
  createdAt    DateTime @default(now())

  @@unique([email, cityId])
  @@index([cityId])
}

enum VehicleCategory {
  BUS
  TRAM
}

model Vehicle {
  id          String              @id @default(uuid())
  number      String
  depot       String
  type        String
  category    VehicleCategory
  cityId      String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments VehicleAssignment[]

  @@unique([number, cityId])
  @@index([cityId])
}

model VehicleAssignment {
  id          String    @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  line        String
  brigade     String
  date        DateTime  @db.Date
  loggedInAt  DateTime  @default(now())
  loggedOutAt DateTime?
  cityId      String

  @@index([cityId, date])
  @@index([vehicleId, date])
}

model Line {
  id          String   @id @default(uuid())
  zditmId     Int      @unique
  number      String
  type        String   // day | night
  subtype     String   // normal | semi-fast | fast | replacement | additional | special | tourist
  vehicleType String   // bus | tram | skm
  onDemand    Boolean  @default(false)
  highlighted Boolean  @default(false)
  sortOrder   Int      @default(0)
  depots      String[] // zajezdnie obsługujące linię (np. ["SPAK", "PKS"])
  cityId      String

  @@unique([number, cityId])
  @@index([cityId])
}

model Stop {
  id                 String  @id @default(uuid())
  zditmId            Int     @unique
  number             String
  name               String
  lat                Float
  lng                Float
  requestStop        Boolean @default(false)
  parkAndRide        Boolean @default(false)
  technical          Boolean @default(false)
  railwayStationName String?
  cityId             String

  @@index([cityId])
  @@index([name, cityId])
}
